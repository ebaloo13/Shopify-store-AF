        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "How far in advance should I book?",
            "answer": "<p>We recommend booking at least 3 months ahead for peak season events, and 6 weeks for off-season trips. Last-minute requests are possible but availability is limited.</p>"
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "Can I customize an existing package?",
            "answer": "<p>Absolutely! Every package can be extended, shortened, or modified. Add extra destinations, swap hotels, include bike rental — it's your trip.</p>"
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "What rider levels do you cater to?",
            "answer": "<p>All levels from beginner to expert. We match trails, guides, and pace to your group's ability so everyone has a great time.</p>"
          }
        },
        "faq_4": {
          "type": "faq",
          "settings": {
            "question": "What's included in the price?",
            "answer": "<p>Base packages typically include accommodation, trail access, and local transport. Extras like bike rental, guided park days, and airport transfers can be added.</p>"
          }
