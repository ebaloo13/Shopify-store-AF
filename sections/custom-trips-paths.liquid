<section
  class="ct-paths color-{{ section.settings.color_scheme }}"
  style="
    --ct-paths-padding-top: {{ section.settings.padding_top | default: 48 }}px;
    --ct-paths-padding-bottom: {{ section.settings.padding_bottom | default: 48 }}px;
  "
>
  <div class="ct-paths__container">
    {%- comment -%} Section header {%- endcomment -%}
    {% if section.settings.heading != blank %}
      <h2 class="ct-paths__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="ct-paths__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {%- comment -%} Two-card grid {%- endcomment -%}
    <div class="ct-paths__grid">
      {%- comment -%} Card A: Build from Scratch {%- endcomment -%}
      <a
        href="#custom-trip-form"
        class="ct-paths__card"
        data-ct-path="scratch"
        aria-label="{{ section.settings.card_a_title | default: 'Build from Scratch' | escape }}"
      >
        {% if section.settings.card_a_image != blank %}
          <div class="ct-paths__card-media">
            <img
              src="{{ section.settings.card_a_image | image_url: width: 800 }}"
              srcset="{{ section.settings.card_a_image | image_url: width: 400 }} 400w,
                      {{ section.settings.card_a_image | image_url: width: 600 }} 600w,
                      {{ section.settings.card_a_image | image_url: width: 800 }} 800w"
              sizes="(max-width: 749px) 100vw, 50vw"
              alt=""
              role="presentation"
              loading="lazy"
              width="800"
              height="600"
              class="ct-paths__card-img"
            >
          </div>
        {% endif %}
        <div class="ct-paths__card-content">
          <h3 class="ct-paths__card-title">{{ section.settings.card_a_title | default: 'Build from Scratch' }}</h3>
          {% if section.settings.card_a_description != blank %}
            <p class="ct-paths__card-desc">{{ section.settings.card_a_description }}</p>
          {% endif %}
          <span class="button-secondary ct-paths__card-cta">
            {{ section.settings.card_a_button_label | default: 'Start Building' }}
          </span>
        </div>
      </a>

      {%- comment -%} Card B: Customize Package {%- endcomment -%}
      <a
        href="#custom-trip-form"
        class="ct-paths__card"
        data-ct-path="customize"
        aria-label="{{ section.settings.card_b_title | default: 'Customize a Package' | escape }}"
      >
        {% if section.settings.card_b_image != blank %}
          <div class="ct-paths__card-media">
            <img
              src="{{ section.settings.card_b_image | image_url: width: 800 }}"
              srcset="{{ section.settings.card_b_image | image_url: width: 400 }} 400w,
                      {{ section.settings.card_b_image | image_url: width: 600 }} 600w,
                      {{ section.settings.card_b_image | image_url: width: 800 }} 800w"
              sizes="(max-width: 749px) 100vw, 50vw"
              alt=""
              role="presentation"
              loading="lazy"
              width="800"
              height="600"
              class="ct-paths__card-img"
            >
          </div>
        {% endif %}
        <div class="ct-paths__card-content">
          <h3 class="ct-paths__card-title">{{ section.settings.card_b_title | default: 'Customize a Package' }}</h3>
          {% if section.settings.card_b_description != blank %}
            <p class="ct-paths__card-desc">{{ section.settings.card_b_description }}</p>
          {% endif %}
          <span class="button-secondary ct-paths__card-cta">
            {{ section.settings.card_b_button_label | default: 'Choose a Package' }}
          </span>
        </div>
      </a>
    </div>
  </div>
</section>

{%- comment -%}
  Minimal progressive-enhancement JS:
  Pre-selects the correct radio in the form section when a card is clicked.
  Without JS, the anchor still scrolls to the form — user picks the radio manually.
{%- endcomment -%}
<script>
  (function () {
    var cards = document.querySelectorAll('[data-ct-path]');
    cards.forEach(function (card) {
      card.addEventListener('click', function (e) {
        var path = card.getAttribute('data-ct-path');
        var radioId = path === 'scratch' ? 'ct-path-scratch' : 'ct-path-customize';
        var radio = document.getElementById(radioId);
        if (radio) {
          radio.checked = true;
          radio.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    });
  })();
</script>

{% stylesheet %}
  .ct-paths {
    padding-block-start: var(--ct-paths-padding-top);
    padding-block-end: var(--ct-paths-padding-bottom);
  }

  .ct-paths__container {
    max-width: var(--normal-page-width);
    margin-inline: auto;
    padding-inline: var(--padding-2xl);
  }

  .ct-paths__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-h2--size);
    line-height: var(--font-h2--line-height);
    letter-spacing: var(--font-h2--letter-spacing);
    color: var(--color-foreground-heading);
    margin: 0 0 var(--margin-sm);
    text-align: center;
  }

  .ct-paths__subheading {
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
    color: var(--color-foreground-muted);
    margin: 0 0 var(--margin-4xl);
    text-align: center;
    max-width: var(--normal-content-width);
    margin-inline: auto;
  }

  .ct-paths__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-2xl);
    max-width: var(--wide-content-width);
    margin-inline: auto;

    @media screen and (min-width: 750px) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ct-paths__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-foreground);
    border: var(--style-border-width) solid var(--color-border);
    border-radius: var(--style-border-radius-md);
    background-color: var(--color-background);
    overflow: hidden;
    transition: border-color var(--animation-speed) var(--animation-easing),
                box-shadow var(--animation-speed) var(--animation-easing);
  }

  .ct-paths__card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgb(var(--color-shadow-rgb) / var(--opacity-10));
  }

  .ct-paths__card:focus-visible {
    outline: var(--focus-outline-width) solid var(--color-foreground);
    outline-offset: var(--focus-outline-offset);
  }

  .ct-paths__card-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .ct-paths__card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--animation-speed-slow) var(--animation-easing);
  }

  .ct-paths__card:hover .ct-paths__card-img {
    transform: scale(1.03);
  }

  .ct-paths__card-content {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
    padding: var(--padding-xl);
    flex-grow: 1;
  }

  .ct-paths__card-title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-h3--size);
    line-height: var(--font-h3--line-height);
    color: var(--color-foreground-heading);
    margin: 0;
  }

  .ct-paths__card-desc {
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
    color: var(--color-foreground-muted);
    margin: 0;
    flex-grow: 1;
  }

  .ct-paths__card-cta {
    margin-block-start: var(--margin-sm);
    align-self: flex-start;
  }

  @media (prefers-reduced-motion: reduce) {
    .ct-paths__card,
    .ct-paths__card-img {
      transition: none;
    }

    .ct-paths__card:hover .ct-paths__card-img {
      transform: none;
    }
  }
{% endstylesheet %}

