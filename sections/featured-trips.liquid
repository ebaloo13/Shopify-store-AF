{% liquid
  assign collection = section.settings.collection | default: collections['packages'] | default: collections.all
  assign max_items = section.settings.max_items | default: 3
%}

<section
  class="featured-trips"
  style="
    --ft-bg: {{ section.settings.background_color | default: '#f8f8f8' }};
    --ft-padding-top: {{ section.settings.padding_top | default: 48 }}px;
    --ft-padding-bottom: {{ section.settings.padding_bottom | default: 48 }}px;
  "
>
  <div class="featured-trips__container">
    {% if section.settings.heading != blank %}
      <h2 class="featured-trips__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="featured-trips__grid">
      {% if collection.products.size > 0 %}
        {% for product in collection.products limit: max_items %}
          {% render 'product-card-trip', product: product %}
        {% endfor %}
      {% else %}
        {% for i in (1..max_items) %}
          {% render 'product-card-trip', product: null %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_button %}
      <div class="featured-trips__cta">
        {% liquid
          assign button_url = section.settings.button_link
          if button_url == blank
            assign button_url = collection.url
          endif
        %}
        <a href="{{ button_url }}" class="featured-trips__button">
          {{ section.settings.button_label | default: 'More Tours' }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% style %}
  /* Featured Trips Section */
  .featured-trips {
    background-color: var(--ft-bg, #f8f8f8);
    padding-top: var(--ft-padding-top, 48px);
    padding-bottom: var(--ft-padding-bottom, 48px);
  }

  .featured-trips__container {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .featured-trips__heading {
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .featured-trips__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  @media (max-width: 1199px) {
    .featured-trips__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 989px) {
    .featured-trips__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media (max-width: 749px) {
    .featured-trips__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .featured-trips__heading {
      font-size: 1.5rem;
    }
  }

  .featured-trips__cta {
    text-align: center;
    margin-top: 2rem;
  }

  .featured-trips__button {
    display: inline-block;
    padding: 0.75rem 2rem;
    background-color: var(--color-button, #000);
    color: var(--color-button-text, #fff);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .featured-trips__button:hover {
    opacity: 0.85;
  }

  /* Trip Card Styles */
  .trip-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: #1a3a32;
    height: 100%;
  }

  .trip-card:hover .trip-card__img {
    transform: scale(1.03);
  }

  .trip-card__image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: #e5e5e5;
    border-radius: 4px;
  }

  .trip-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .trip-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .trip-card__content {
    padding: 1rem 0.5rem;
    background-color: #EEF1EA;
    margin-top: -2rem;
    margin-left: 0.5rem;
    margin-right: 0.5rem;
    position: relative;
    z-index: 1;
    border-radius: 2px;
    flex-grow: 1;
  }

  .trip-card__title {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 0.375rem;
    line-height: 1.2;
    color: #1a3a32;
  }

  .trip-card__type {
    font-size: 0.8125rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    color: #1a3a32;
  }

  .trip-card__meta {
    font-size: 0.75rem;
    margin: 0 0 0.5rem;
    color: #1a3a32;
    display: flex;
    gap: 1.5rem;
  }

  .trip-card__location {
    font-weight: 400;
  }

  .trip-card__duration {
    font-weight: 400;
  }

  .trip-card__description {
    font-size: 0.75rem;
    font-style: italic;
    margin: 0;
    color: #1a3a32;
    line-height: 1.4;
    opacity: 0.85;
  }

  .trip-card--placeholder {
    pointer-events: none;
  }
{% endstyle %}

{% schema %}
{
  "name": "Featured Trips",
  "class": "section-featured-trips",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Trips"
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Maximum products",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "More Tours"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f8f8"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Featured Trips",
      "category": "Products",
      "settings": {
        "heading": "Featured Trips",
        "max_items": 4,
        "show_button": false,
        "button_label": "More Tours",
        "background_color": "#f8f8f8",
        "padding_top": 48,
        "padding_bottom": 48
      }
    }
  ]
}
{% endschema %}
