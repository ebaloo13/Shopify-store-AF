{% liquid
  assign min_height = section.settings.min_height | default: 500
  assign min_height_mobile = section.settings.min_height_mobile | default: 400
  assign overlay_opacity = section.settings.overlay_opacity | default: 40
  assign overlay_decimal = overlay_opacity | divided_by: 100.0
  assign text_alignment = section.settings.text_alignment | default: 'center'
  assign overlay_color = section.settings.overlay_color | default: '#000000'
  assign overlay_r = overlay_color | color_extract: 'red'
  assign overlay_g = overlay_color | color_extract: 'green'
  assign overlay_b = overlay_color | color_extract: 'blue'
  assign text_color = section.settings.text_color | default: '#ffffff'
%}

<section
  class="ct-hero color-{{ section.settings.color_scheme }}"
  style="
    --ct-hero-min-height: {{ min_height }}px;
    --ct-hero-min-height-mobile: {{ min_height_mobile }}px;
    --ct-hero-overlay-rgb: {{ overlay_r }} {{ overlay_g }} {{ overlay_b }};
    --ct-hero-overlay-opacity: {{ overlay_decimal }};
    --ct-hero-text-align: {{ text_alignment }};
    --ct-hero-text-color: {{ text_color }};
  "
>
  {%- comment -%} Background image {%- endcomment -%}
  <div class="ct-hero__media">
    {% if section.settings.image != blank %}
      <picture>
        {% if section.settings.image_mobile != blank %}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.image_mobile | image_url: width: 750 }} 750w,
                    {{ section.settings.image_mobile | image_url: width: 1000 }} 1000w"
            sizes="100vw"
          >
        {% endif %}
        <img
          src="{{ section.settings.image | image_url: width: 1920 }}"
          srcset="{{ section.settings.image | image_url: width: 1000 }} 1000w,
                  {{ section.settings.image | image_url: width: 1500 }} 1500w,
                  {{ section.settings.image | image_url: width: 1920 }} 1920w"
          sizes="100vw"
          alt="{{ section.settings.heading | escape }}"
          loading="eager"
          class="ct-hero__img"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      </picture>
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'ct-hero__placeholder' }}
    {% endif %}
  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  <div class="ct-hero__overlay" aria-hidden="true"></div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="ct-hero__content">
    {% if section.settings.heading != blank %}
      <h1 class="ct-hero__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="ct-hero__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a
        href="{{ section.settings.button_link | default: '#custom-trip-form' }}"
        class="button ct-hero__cta"
      >
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .ct-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--ct-hero-min-height-mobile);
    overflow: hidden;
    text-align: var(--ct-hero-text-align, center);

    @media screen and (min-width: 750px) {
      min-height: var(--ct-hero-min-height);
    }
  }

  .ct-hero__media {
    position: absolute;
    inset: 0;
    z-index: var(--layer-section-background);
  }

  .ct-hero__img,
  .ct-hero__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ct-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: var(--layer-base);
    background: rgb(var(--ct-hero-overlay-rgb, 0 0 0) / var(--ct-hero-overlay-opacity, 0.4));
  }

  .ct-hero__content {
    position: relative;
    z-index: var(--layer-flat);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-lg);
    max-width: var(--normal-page-width);
    padding-inline: var(--padding-2xl);
    padding-block: var(--padding-5xl);
    color: var(--ct-hero-text-color, #ffffff);
  }

  .ct-hero__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-h1--size);
    line-height: var(--font-h1--line-height);
    letter-spacing: var(--font-h1--letter-spacing);
    color: inherit;
    margin: 0;
  }

  .ct-hero__subheading {
    font-family: var(--font-body--family);
    font-size: var(--font-size--lg);
    line-height: var(--font-paragraph--line-height);
    color: inherit;
    margin: 0;
    max-width: var(--normal-content-width);
    opacity: var(--opacity-90);
  }

  .ct-hero__cta {
    margin-block-start: var(--margin-sm);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Trips Hero",
  "tag": "section",
  "class": "ct-hero-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min Height (px)",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Mobile Min Height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Design Your Dream MTB Trip"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From single-day events to multi-week adventures — we build the ride of your life."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Start Planning"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom Trips Hero",
      "settings": {
        "heading": "Design Your Dream MTB Trip",
        "subheading": "From single-day events to multi-week adventures — we build the ride of your life.",
        "button_label": "Start Planning",
        "overlay_opacity": 40,
        "text_alignment": "center",
        "min_height": 500,
        "min_height_mobile": 400
      }
    }
  ]
}
{% endschema %}
