{% liquid
  assign has_faq_blocks = false
  assign has_trust_blocks = false
  for block in section.blocks
    if block.type == 'faq'
      assign has_faq_blocks = true
    endif
    if block.type == 'trust_badge'
      assign has_trust_blocks = true
    endif
  endfor
%}

<section
  class="ct-faq color-{{ section.settings.color_scheme }}"
  style="
    --ct-faq-padding-top: {{ section.settings.padding_top | default: 48 }}px;
    --ct-faq-padding-bottom: {{ section.settings.padding_bottom | default: 48 }}px;
  "
>
  <div class="ct-faq__container">
    {%- comment -%} Section header {%- endcomment -%}
    {% if section.settings.heading != blank %}
      <h2 class="ct-faq__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="ct-faq__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {%- comment -%} FAQ accordion {%- endcomment -%}
    {% if has_faq_blocks %}
      <div class="ct-faq__list" role="region" aria-label="{{ section.settings.heading | default: 'FAQ' | escape }}">
        {% for block in section.blocks %}
          {% if block.type == 'faq' %}
            <details class="ct-faq__item" {{ block.shopify_attributes }}>
              <summary class="ct-faq__question">
                <span class="ct-faq__question-text">{{ block.settings.question }}</span>
                <span class="ct-faq__chevron" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 6l4 4 4-4"/>
                  </svg>
                </span>
              </summary>
              <div class="ct-faq__answer rte">
                {{ block.settings.answer }}
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {%- comment -%} Trust badges {%- endcomment -%}
    {% if has_trust_blocks %}
      <div class="ct-faq__trust-badges">
        {% for block in section.blocks %}
          {% if block.type == 'trust_badge' %}
            <div class="ct-faq__badge" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <img
                  src="{{ block.settings.icon | image_url: width: 64 }}"
                  alt=""
                  role="presentation"
                  width="32"
                  height="32"
                  loading="lazy"
                  class="ct-faq__badge-icon"
                >
              {% endif %}
              {% if block.settings.text != blank %}
                <span class="ct-faq__badge-text">{{ block.settings.text }}</span>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .ct-faq {
    padding-block-start: var(--ct-faq-padding-top);
    padding-block-end: var(--ct-faq-padding-bottom);
  }

  .ct-faq__container {
    max-width: var(--normal-page-width);
    margin-inline: auto;
    padding-inline: var(--padding-2xl);
  }

  .ct-faq__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-h2--size);
    line-height: var(--font-h2--line-height);
    letter-spacing: var(--font-h2--letter-spacing);
    color: var(--color-foreground-heading);
    margin: 0 0 var(--margin-sm);
    text-align: center;
  }

  .ct-faq__subheading {
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
    color: var(--color-foreground-muted);
    margin: 0 0 var(--margin-4xl);
    text-align: center;
    max-width: var(--normal-content-width);
    margin-inline: auto;
  }

  .ct-faq__list {
    max-width: var(--wide-content-width);
    margin-inline: auto;
  }

  .ct-faq__item {
    border-block-end: var(--style-border-width) solid var(--color-border);
  }

  .ct-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-lg);
    padding-block: var(--padding-lg);
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: var(--font-size--lg);
    font-weight: 600;
    line-height: var(--font-paragraph--line-height);
    color: var(--color-foreground);
    list-style: none;
  }

  /* Remove default marker */
  .ct-faq__question::-webkit-details-marker {
    display: none;
  }

  .ct-faq__question-text {
    flex: 1;
    min-width: 0;
  }

  .ct-faq__chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-foreground);
    transition: transform var(--animation-speed) var(--animation-easing);
  }

  .ct-faq__item[open] .ct-faq__chevron {
    transform: rotate(180deg);
  }

  .ct-faq__answer {
    padding-block-end: var(--padding-lg);
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
    color: var(--color-foreground);
  }

  /* Trust badges */
  .ct-faq__trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--gap-xl);
    margin-block-start: var(--margin-5xl);
    padding-block-start: var(--padding-4xl);
    border-block-start: var(--style-border-width) solid var(--color-border);
  }

  .ct-faq__badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-xs);
    text-align: center;
  }

  .ct-faq__badge-icon {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .ct-faq__badge-text {
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    color: var(--color-foreground);
    font-weight: 500;
  }

  @media (prefers-reduced-motion: reduce) {
    .ct-faq__chevron {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Trips FAQ",
  "tag": "section",
  "class": "ct-faq-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How does it work?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Tell us your dream trip details and we'll put together a custom proposal within 48 hours.</p>"
        }
      ]
    },
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Badge Text",
          "default": "100% Customizable"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Trips FAQ",
      "settings": {
        "heading": "Frequently Asked Questions",
        "padding_top": 48,
        "padding_bottom": 48
      },
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How far in advance should I book?",
            "answer": "<p>We recommend booking at least 3 months ahead for peak season events, and 6 weeks for off-season trips. Last-minute requests are possible but availability is limited.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I customize an existing package?",
            "answer": "<p>Absolutely! Every package can be extended, shortened, or modified. Add extra destinations, swap hotels, include bike rental — it's your trip.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What rider levels do you cater to?",
            "answer": "<p>All levels from beginner to expert. We match trails, guides, and pace to your group's ability so everyone has a great time.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What's included in the price?",
            "answer": "<p>Base packages typically include accommodation, trail access, and local transport. Extras like bike rental, guided park days, and airport transfers can be added.</p>"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "100% Customizable"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "Expert Local Guides"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "Flexible Cancellation"
          }
        }
      ]
    }
  ]
}
{% endschema %}
